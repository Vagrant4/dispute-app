{
  "name": "mobile",
  "private": true,
  "version": "0.1.0",
  "main": "expo/AppEntry",
  "scripts": {
    "prestart": "npm run build --workspace @claimproof/shared",
    "start": "expo start",
    "preandroid": "npm run build --workspace @claimproof/shared",
    "android": "expo run:android",
    "preios": "npm run build --workspace @claimproof/shared",
    "ios": "expo run:ios",
    "preweb": "npm run build --workspace @claimproof/shared",
    "web": "expo start --web",
    "pretypecheck": "npm run build --workspace @claimproof/shared",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build --workspace @claimproof/shared",
    "test": "node --test tests/*.test.js",
    "eas-build-post-install": "npm run build --workspace @claimproof/shared"
  },
  "dependencies": {
    "@claimproof/shared": "file:../packages/shared",
    "expo": "~56.0.15",
    "expo-crypto": "^56.0.4",
    "expo-dev-client": "~56.0.22",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-image-picker": "~56.0.20",
    "expo-location": "~56.0.20",
    "expo-print": "~56.0.4",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.21",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "0.85.3",
    "react-native-purchases": "^10.4.4",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "typescript": "~6.0.3"
  }
}
