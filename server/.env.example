DATABASE_URL="file:./dev.db"
JWT_SECRET="replace-with-a-long-random-secret-for-production"
CLIENT_ORIGIN="http://localhost:5173"

# Gmail SMTP for a few verification-email tests.
# Use a Google App Password here, not your normal Gmail password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-gmail-address@gmail.com"
SMTP_PASS="your-google-app-password"
EMAIL_FROM="Dispute <your-gmail-address@gmail.com>"

# Billing stays disabled until Stripe checkout and webhook signature verification are ready.
STRIPE_BILLING_MODE="disabled"
