generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  WORKER
  ADMIN_PLACEHOLDER
}

enum UserStatus {
  PENDING_EMAIL_VERIFICATION
  ACTIVE
  SUSPENDED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum EmploymentType {
  HOURLY
  DAILY
  MONTHLY
  FREELANCER
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum TimeEntryStatus {
  DRAFT
  FINALIZED
}

enum EvidenceType {
  BEFORE_WORK
  DURING_WORK
  AFTER_WORK
  DEFECT
  COMPLETED_WORK
  MATERIAL_DELIVERY
  VARIATION_WORK
  OTHER
}

enum RateType {
  HOURLY
  DAILY
  MONTHLY
  FREELANCER
}

model User {
  id              String      @id @default(cuid())
  email           String      @unique
  passwordHash    String
  role            UserRole    @default(WORKER)
  status          UserStatus  @default(PENDING_EMAIL_VERIFICATION)
  emailVerifiedAt DateTime?
  lastSeenAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  profile              WorkerProfile?
  companies            Company[]
  projects             Project[]
  timeEntries          TimeEntry[]
  photoEvidence        PhotoEvidence[]
  paySummaries         PaySummary[]
  progressClaimReports ProgressClaimReport[]
  appSetting           AppSetting?
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens  PasswordResetToken[]
  subscriptions        UserSubscription[]
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model WorkerProfile {
  id                   String         @id @default(cuid())
  userId               String         @unique
  fullName             String
  phone                String
  workerIdentifier     String?
  finNric              String?
  trade                String
  employmentType       EmploymentType
  defaultHourlyRate    Decimal?
  defaultDailyRate     Decimal?
  defaultMonthlySalary Decimal?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id            String   @id @default(cuid())
  userId        String
  name          String
  uen           String?
  contactPerson String
  email         String
  phone         String
  address       String
  notes         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@index([userId])
  @@unique([id, userId])
}

model Project {
  id                  String        @id @default(cuid())
  userId              String
  companyId           String?
  projectName         String
  siteAddress         String
  poOrWorkOrderNumber String?
  startDate           DateTime
  endDate             DateTime?
  description         String
  defaultHourlyRate   Decimal?
  defaultDailyRate    Decimal?
  status              ProjectStatus @default(ACTIVE)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  company              Company?              @relation(fields: [companyId, userId], references: [id, userId], onDelete: NoAction)
  timeEntries          TimeEntry[]
  photoEvidence        PhotoEvidence[]
  paySummaries         PaySummary[]
  progressClaimReports ProgressClaimReport[]

  @@index([userId])
  @@index([companyId])
  @@unique([id, userId])
}

model TimeEntry {
  id              String          @id @default(cuid())
  userId          String
  projectId       String
  date            DateTime
  clockInTime     DateTime
  clockOutTime    DateTime?
  breakMinutes    Int
  totalHours      Float
  overtimeHours   Float
  workDescription String
  manualEntryFlag Boolean         @default(false)
  locationText    String
  clockInGpsLat   Float?
  clockInGpsLng   Float?
  clockOutGpsLat  Float?
  clockOutGpsLng  Float?
  status          TimeEntryStatus @default(DRAFT)
  notes           String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project       Project         @relation(fields: [projectId, userId], references: [id, userId], onDelete: Cascade)
  photoEvidence PhotoEvidence[]

  @@index([userId])
  @@index([projectId])
  @@unique([id, userId])
  @@unique([id, projectId, userId])
}

model PhotoEvidence {
  id           String       @id @default(cuid())
  userId       String
  projectId    String
  timeEntryId  String?
  imagePath    String
  caption      String
  evidenceType EvidenceType
  timestamp    DateTime
  gpsLat       Float?
  gpsLng       Float?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project    @relation(fields: [projectId, userId], references: [id, userId], onDelete: Cascade)
  timeEntry TimeEntry? @relation(fields: [timeEntryId, projectId, userId], references: [id, projectId, userId], onDelete: NoAction)

  @@index([userId])
  @@index([projectId])
  @@index([timeEntryId])
}

model PaySummary {
  id                  String   @id @default(cuid())
  userId              String
  projectId           String?
  salaryPeriodStart   DateTime
  salaryPeriodEnd     DateTime
  rateType            RateType
  basicRate           Decimal
  basicPay            Decimal
  overtimeRate        Decimal
  overtimePay         Decimal
  restDayPay          Decimal
  publicHolidayPay    Decimal
  totalAllowances     Decimal
  totalDeductions     Decimal
  grossPay            Decimal
  netPay              Decimal
  itemisedPayslipJson String
  notes               String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project?    @relation(fields: [projectId, userId], references: [id, userId], onDelete: NoAction)
  allowances Allowance[]
  deductions Deduction[]

  @@index([userId])
  @@index([projectId])
}

model Allowance {
  id           String  @id @default(cuid())
  paySummaryId String
  description  String
  amount       Decimal

  paySummary PaySummary @relation(fields: [paySummaryId], references: [id], onDelete: Cascade)

  @@index([paySummaryId])
}

model Deduction {
  id           String  @id @default(cuid())
  paySummaryId String
  description  String
  amount       Decimal

  paySummary PaySummary @relation(fields: [paySummaryId], references: [id], onDelete: Cascade)

  @@index([paySummaryId])
}

model ProgressClaimReport {
  id                     String   @id @default(cuid())
  userId                 String
  projectId              String
  companySnapshotJson    String
  workerSnapshotJson     String
  projectSnapshotJson    String
  claimPeriodStart       DateTime
  claimPeriodEnd         DateTime
  totalDaysWorked        Int
  totalHours             Float
  totalOvertimeHours     Float
  totalClaimAmount       Decimal
  entriesSnapshotJson    String
  photosSnapshotJson     String
  pdfPath                String
  csvPath                String
  notes                  String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId, userId], references: [id, userId], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
}

model AppSetting {
  id                  String   @id @default(cuid())
  userId              String
  standardDailyHours  Float    @default(8)
  standardWeeklyHours Float    @default(44)
  overtimeMultiplier  Float    @default(1.5)
  defaultCurrency     String   @default("SGD")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model SubscriptionPlan {
  id             String  @id @default(cuid())
  name           String
  price          Decimal
  currency       String  @default("SGD")
  billingInterval String @default("month")
  limitsJson     String
  status         String

  subscriptions UserSubscription[]
}

model UserSubscription {
  id                   String             @id @default(cuid())
  userId               String
  planId               String
  status               SubscriptionStatus
  monthlyRecurringCents Int
  currency             String             @default("SGD")
  provider             String             @default("manual")
  providerSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([planId])
  @@index([status])
}
