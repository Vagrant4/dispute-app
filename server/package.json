{
  "name": "server",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build --workspace @claimproof/shared",
    "dev": "tsx watch src/server.ts",
    "prebuild": "npm run build --workspace @claimproof/shared",
    "build": "tsc -p tsconfig.json",
    "pretest": "npm run build --workspace @claimproof/shared",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@claimproof/shared": "file:../packages/shared",
    "@prisma/client": "6.19.3",
    "bcryptjs": "latest",
    "cookie-parser": "latest",
    "cors": "latest",
    "express": "latest",
    "jsonwebtoken": "latest",
    "multer": "latest",
    "pdfkit": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/cookie-parser": "latest",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/multer": "latest",
    "@types/node": "latest",
    "@types/pdfkit": "latest",
    "prisma": "6.19.3",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
